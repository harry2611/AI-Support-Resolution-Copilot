# Shared
OPENAI_API_KEY=

# Backend
DATABASE_URL=postgresql+psycopg://copilot:copilot@db:5432/copilot
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
CORS_ORIGINS=["http://localhost:3000"]
WEB_FALLBACK_ENABLED=true
WEB_FALLBACK_CONFIDENCE_THRESHOLD=0.35
WEB_FALLBACK_MAX_REFERENCES=5
GUARDRAILS_ENABLED=true
PII_MASKING_ENABLED=true
PROMPT_INJECTION_DETECTION_ENABLED=true
POLICY_FILTERING_ENABLED=true
LANGSMITH_TRACING_ENABLED=false
LANGSMITH_PROJECT=resolveai
LANGSMITH_API_KEY=

# Scheduled sync
SYNC_SCHEDULER_ENABLED=true
SYNC_INTERVAL_MINUTES=60
SYNC_ON_STARTUP=false

# Confluence connector
CONFLUENCE_ENABLED=false
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEYS=
CONFLUENCE_PAGE_LIMIT=25

# Notion connector
NOTION_ENABLED=false
NOTION_API_TOKEN=
NOTION_DATABASE_IDS=
NOTION_PAGE_LIMIT=25

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
